# keqing-shell: auto-generated

[mgr]
cwd = { fg = "${ACCENT}" }

find_keyword  = { fg = "${ROSE}", bold = true, italic = true, underline = true }
find_position = { fg = "${LAVENDER_LIGHT}", bg = "reset", bold = true, italic = true }

marker_copied   = { fg = "#a8e6cf", bg = "#a8e6cf" }
marker_cut      = { fg = "${ROSE}", bg = "${ROSE}" }
marker_marked   = { fg = "${BASE}", bg = "${LAVENDER_LIGHT}" }
marker_selected = { fg = "${ACCENT_ALT}", bg = "${ACCENT_ALT}" }

count_copied   = { fg = "${BASE}", bg = "#a8e6cf" }
count_cut      = { fg = "${BASE}", bg = "${ROSE}" }
count_selected = { fg = "${BASE}", bg = "${ACCENT}" }

border_symbol = "│"
border_style  = { fg = "${OVERLAY}" }


[tabs]
active   = { fg = "${BASE}", bg = "${ACCENT}", bold = true }
inactive = { fg = "${ACCENT}", bg = "${SURFACE}" }


[mode]
normal_main = { fg = "${BASE}", bg = "${ACCENT}", bold = true }
normal_alt  = { fg = "${ACCENT}", bg = "${SURFACE}" }

select_main = { fg = "${BASE}", bg = "#a8e6cf", bold = true }
select_alt  = { fg = "${ACCENT}", bg = "${SURFACE}" }

unset_main = { fg = "${BASE}", bg = "${LAVENDER_LIGHT}", bold = true }
unset_alt  = { fg = "${ACCENT}", bg = "${SURFACE}" }


[status]
overall   = { fg = "${ACCENT}" }
sep_left  = { open = "", close = "" }
sep_right = { open = "", close = "" }

progress_label  = { fg = "${TEXT}", bold = true }
progress_normal = { fg = "${ACCENT}", bg = "${SURFACE}" }
progress_error  = { fg = "${ROSE}", bg = "${SURFACE}" }

perm_sep   = { fg = "${LAVENDER}" }
perm_type  = { fg = "#a8e6cf" }
perm_read  = { fg = "${ACCENT_ALT}" }
perm_write = { fg = "${ROSE}" }
perm_exec  = { fg = "${LAVENDER_LIGHT}" }


[pick]
border   = { fg = "${ACCENT}" }
active   = { fg = "${LAVENDER_LIGHT}", bold = true }
inactive = {}


[input]
border   = { fg = "${ACCENT}" }
title    = {}
value    = {}
selected = { reversed = true }


[cmp]
border = { fg = "${ACCENT}" }


[tasks]
border  = { fg = "${ACCENT}" }
title   = {}
hovered = { fg = "${LAVENDER_LIGHT}", underline = true }


[which]
mask            = { bg = "${OVERLAY}" }
cand            = { fg = "${ACCENT_ALT}" }
rest            = { fg = "${TEXT_MUTED}" }
desc            = { fg = "${LAVENDER}" }
separator       = "  "
separator_style = { fg = "${TEXT_MUTED}" }


[help]
on      = { fg = "#a8e6cf" }
run     = { fg = "${LAVENDER_LIGHT}" }
hovered = { reversed = true, bold = true }
footer  = { fg = "${BASE}", bg = "${TEXT_MUTED}" }


[spot]
border   = { fg = "${ACCENT}" }
title    = { fg = "${ACCENT}" }
tbl_col  = { fg = "#a8e6cf" }
tbl_cell = { fg = "${LAVENDER_LIGHT}", bg = "${SURFACE}" }


[notify]
title_info  = { fg = "#a8e6cf" }
title_warn  = { fg = "${ACCENT_ALT}" }
title_error = { fg = "${ROSE}" }


[filetype]
rules = [
    { mime = "image/*", fg = "${ACCENT_ALT}" },
    { mime = "video/*", fg = "${ROSE}" },
    { mime = "audio/*", fg = "${ROSE}" },
    { mime = "application/zip",             fg = "${LAVENDER_LIGHT}" },
    { mime = "application/x-tar",           fg = "${LAVENDER_LIGHT}" },
    { mime = "application/x-bzip*",         fg = "${LAVENDER_LIGHT}" },
    { mime = "application/x-bzip2",         fg = "${LAVENDER_LIGHT}" },
    { mime = "application/x-7z-compressed", fg = "${LAVENDER_LIGHT}" },
    { mime = "application/x-rar",           fg = "${LAVENDER_LIGHT}" },
    { mime = "application/x-xz",            fg = "${LAVENDER_LIGHT}" },
    { mime = "application/doc",        fg = "#a8e6cf" },
    { mime = "application/epub+zip",   fg = "#a8e6cf" },
    { mime = "application/pdf",        fg = "#a8e6cf" },
    { mime = "application/rtf",        fg = "#a8e6cf" },
    { mime = "application/vnd.*",      fg = "#a8e6cf" },
    { mime = "*", is = "orphan", fg = "${ROSE}", bg = "${ACCENT_CONTAINER}" },
    { mime = "application/*exec*", fg = "${ROSE}" },
    { url = "*", fg = "${TEXT}" },
    { url = "*/", fg = "${ACCENT}" },
]
