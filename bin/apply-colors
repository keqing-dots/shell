#!/usr/bin/env bash
# Applies keqing-shell colors to all themed applications.

COLORS_JSON="$HOME/.config/keqing-shell/colors.json"

color() {
    local val
    val=$(jq -r "$1 // empty" "$COLORS_JSON" 2>/dev/null)
    echo "${val:-$2}"
}

safe_write() { [[ -L "$1" && ! -e "$1" ]] && rm -f "$1"; }

accent=$(color '.current.accent' '#7B2FE8')
accentContainer=$(color '.current.accentContainer' '#3D1878')
accentAlt=$(color '.current.accentAlt' '#C8942A')
lavender=$(color '.current.lavender' '#5E50A0')
text=$(color '.current.text' '#F0ECF8')
textMuted=$(color '.current.textMuted' '#A896C8')
fieldBg=$(color '.current.fieldBg' '#0F1535')
surfaceAlt=$(color '.current.surfaceAlt' '#1A1238')
base=$(color '.current.base' '#0A0614')

# =====
# kitty
# =====
apply_kitty() {
    local file="$HOME/.config/kitty/current-theme.conf"
    mkdir -p "$(dirname "$file")"
    safe_write "$file"
    cat > "$file" << EOF
background            $base
foreground            $text
cursor                $text
cursor_text_color     $base
selection_foreground  $textMuted
selection_background  $surfaceAlt
active_border_color   $accent
inactive_border_color $surfaceAlt
url_color             $lavender
active_tab_foreground $base
active_tab_background $accent
inactive_tab_foreground $textMuted
inactive_tab_background $surfaceAlt
cursor_trail_color    $lavender

color0  $base
color1  #ff6b6b
color2  #a8e6cf
color3  $accentAlt
color4  $accentContainer
color5  $accent
color6  $lavender
color7  $text
color8  $surfaceAlt
color9  #ff8e8e
color10 #c3f0d8
color11 $accentAlt
color12 $fieldBg
color13 $lavender
color14 $textMuted
color15 $text
EOF
    pkill -USR1 kitty 2>/dev/null && echo "kitty: reloaded" || echo "kitty: config written"
}

# ====
# cava
# ====
apply_cava() {
    local file="$HOME/.config/cava/config"
    mkdir -p "$(dirname "$file")"
    safe_write "$file"

    mapfile -t gradient < <(python3 - "$accent" "$lavender" << 'PY'
import sys

def lerp_hex(c1, c2, t):
    r1, g1, b1 = int(c1[1:3], 16), int(c1[3:5], 16), int(c1[5:7], 16)
    r2, g2, b2 = int(c2[1:3], 16), int(c2[3:5], 16), int(c2[5:7], 16)
    return "#{:02x}{:02x}{:02x}".format(
        int(r1 + (r2 - r1) * t),
        int(g1 + (g2 - g1) * t),
        int(b1 + (b2 - b1) * t),
    )

c1, c2 = sys.argv[1], sys.argv[2]
for i in range(8):
    print(lerp_hex(c1, c2, i / 7))
PY
    )

    cat > "$file" << EOF
[general]
framerate = 60
autosens = 1
sensitivity = 100
bars = 0
bar_width = 1
bar_spacing = 1
sleep_timer = 0
max_height = 66

[output]
method = noncurses
orientation = bottom
channels = mono
mono_option = average

[color]
background = default
foreground = default
gradient = 1
gradient_color_1 = '${gradient[0]}'
gradient_color_2 = '${gradient[1]}'
gradient_color_3 = '${gradient[2]}'
gradient_color_4 = '${gradient[3]}'
gradient_color_5 = '${gradient[4]}'
gradient_color_6 = '${gradient[5]}'
gradient_color_7 = '${gradient[6]}'
gradient_color_8 = '${gradient[7]}'

[smoothing]
noise_reduction = 77
monstercat = 0
waves = 0

[eq]
1 = 1
2 = 1
3 = 1
4 = 1
5 = 1
EOF
    pkill -USR1 cava 2>/dev/null && echo "cava: reloaded" || echo "cava: config written"
}

# ====
# btop
# ====
apply_btop() {
    local file="$HOME/.config/btop/themes/keqing.theme"
    mkdir -p "$(dirname "$file")"
    safe_write "$file"
    cat > "$file" << EOF
theme[main_bg]="$base"
theme[main_fg]="$text"
theme[title]="$lavender"
theme[hi_fg]="$accentAlt"
theme[selected_bg]="$accentContainer"
theme[selected_fg]="$text"
theme[inactive_fg]="$textMuted"
theme[proc_misc]="$accent"
theme[cpu_box]="$surfaceAlt"
theme[mem_box]="$surfaceAlt"
theme[net_box]="$surfaceAlt"
theme[proc_box]="$surfaceAlt"
theme[div_line]="$surfaceAlt"
theme[temp_start]="$accent"
theme[temp_mid]="$lavender"
theme[temp_end]="$accentAlt"
theme[cpu_start]="$accent"
theme[cpu_mid]="$lavender"
theme[cpu_end]="$accentAlt"
theme[free_start]="$accent"
theme[free_mid]="$lavender"
theme[free_end]="$accentAlt"
theme[cached_start]="$accent"
theme[cached_mid]="$lavender"
theme[cached_end]="$accentAlt"
theme[available_start]="$accent"
theme[available_mid]="$lavender"
theme[available_end]="$accentAlt"
theme[used_start]="$accent"
theme[used_mid]="$lavender"
theme[used_end]="$accentAlt"
theme[download_start]="$accent"
theme[download_mid]="$lavender"
theme[download_end]="$accentAlt"
theme[upload_start]="$accent"
theme[upload_mid]="$lavender"
theme[upload_end]="$accentAlt"
EOF
    echo "btop: theme written (restart btop to apply)"
}

# =======
# vesktop
# =======
apply_vesktop() {
    local file="$HOME/.config/vesktop/settings/quickCss.css"
    mkdir -p "$(dirname "$file")"
    safe_write "$file"
    cat > "$file" << EOF
/* keqing-shell: auto-generated color overrides */
:root {
    --main-color: $accent;
    --hover-color: $lavender;
    --success-color: $accentContainer;
}
EOF
    echo "vesktop: quickCss.css written (hot-reloaded)"
}

apply_kitty
apply_cava
apply_btop
apply_vesktop
hyprctl reload
