#!/usr/bin/env bash

COLORS_JSON="$HOME/.config/keqing-shell/colors.json"
TMPL_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../templates"

color()      { local v; v=$(jq -r "$1 // empty" "$COLORS_JSON" 2>/dev/null); echo "${v:-$2}"; }
hex_to_rgb() { local h="${1#'#'}"; printf "%d;%d;%d" $((16#${h:0:2})) $((16#${h:2:2})) $((16#${h:4:2})); }
lerp_hex()   {
    local c1="${1#'#'}" c2="${2#'#'}" i="$3"
    printf '#%02x%02x%02x' \
        $(( 16#${c1:0:2} + (16#${c2:0:2} - 16#${c1:0:2}) * i / 7 )) \
        $(( 16#${c1:2:2} + (16#${c2:2:2} - 16#${c1:2:2}) * i / 7 )) \
        $(( 16#${c1:4:2} + (16#${c2:4:2} - 16#${c1:4:2}) * i / 7 ))
}
write_file() { local f="$1"; mkdir -p "$(dirname "$f")"; [[ -L "$f" && ! -e "$f" ]] && rm -f "$f"; }
render_tmpl() {
    local tmpl="$1" out="$2"
    [[ -f "$tmpl" ]] || { echo "${tmpl##*/}: not found, skipping"; return; }
    envsubst "$ENVSUBST_VARS" < "$tmpl" > "$out"
}

# palette
export BASE=$(color '.current.base' '#0A0614')
export SURFACE=$(color '.current.surface' '#120B23')
export SURFACE_ALT=$(color '.current.surfaceAlt' '#1D113B')
export OVERLAY=$(color '.current.overlay' '#26164B')
export OVERLAY_ALT=$(color '.current.overlayAlt' '#2F1C5F')
export FIELD_BG=$(color '.current.fieldBg' '#170D30')
export ACCENT=$(color '.current.accent' '#9B57F4')
export ACCENT_ALT=$(color '.current.accentAlt' '#DBAA24')
export ACCENT_DIM=$(color '.current.accentDim' '#693DC2')
export ACCENT_CONTAINER=$(color '.current.accentContainer' '#3C1877')
export ACCENT_ALT_CONTAINER=$(color '.current.accentAltContainer' '#2A1957')
export LAVENDER=$(color '.current.lavender' '#806FBE')
export LAVENDER_LIGHT=$(color '.current.lavenderLight' '#CE8AFF')
export ROSE=$(color '.current.rose' '#C0547F')
export TEXT=$(color '.current.text' '#F0ECF9')
export TEXT_MUTED=$(color '.current.textMuted' '#AB9DC8')

# derived
export ACCENT_RGB=$(hex_to_rgb "$ACCENT")
export LAVENDER_LIGHT_RGB=$(hex_to_rgb "$LAVENDER_LIGHT")
export ACCENT_ALT_RGB=$(hex_to_rgb "$ACCENT_ALT")
for i in 0 1 2 3 4 5 6 7; do
    export "GRADIENT_$((i+1))=$(lerp_hex "$ACCENT" "$LAVENDER" "$i")"
done

ENVSUBST_VARS='$BASE $SURFACE $SURFACE_ALT $OVERLAY $OVERLAY_ALT $FIELD_BG
    $ACCENT $ACCENT_ALT $ACCENT_DIM $ACCENT_CONTAINER $ACCENT_ALT_CONTAINER
    $LAVENDER $LAVENDER_LIGHT $ROSE $TEXT $TEXT_MUTED
    $ACCENT_RGB $LAVENDER_LIGHT_RGB $ACCENT_ALT_RGB
    $GRADIENT_1 $GRADIENT_2 $GRADIENT_3 $GRADIENT_4
    $GRADIENT_5 $GRADIENT_6 $GRADIENT_7 $GRADIENT_8'

apply_kitty() {
    local file="$HOME/.config/kitty/current-theme.conf"
    write_file "$file"
    render_tmpl "$TMPL_DIR/kitty.conf.tmpl" "$file"
    pkill -USR1 kitty 2>/dev/null && echo "kitty: reloaded" || echo "kitty: config written"
}

apply_cava() {
    local file="$HOME/.config/cava/config"
    write_file "$file"
    render_tmpl "$TMPL_DIR/cava.conf.tmpl" "$file"
    pkill -USR1 cava 2>/dev/null && echo "cava: reloaded" || echo "cava: config written"
}

apply_btop() {
    local theme="$HOME/.config/btop/themes/keqing.theme"
    local conf="$HOME/.config/btop/btop.conf"
    write_file "$theme"
    render_tmpl "$TMPL_DIR/btop.theme.tmpl" "$theme"
    for prefix in temp cpu free cached available used download upload; do
        printf 'theme[%s_start]="%s"\ntheme[%s_mid]="%s"\ntheme[%s_end]="%s"\n' \
            "$prefix" "$ACCENT" "$prefix" "$LAVENDER" "$prefix" "$ACCENT_ALT"
    done >> "$theme"
    mkdir -p "$(dirname "$conf")"
    if [[ ! -f "$conf" ]]; then
        printf 'color_theme = "keqing"\ntheme_background = false\ntruecolor = true\n' > "$conf"
    else
        sed -i -e 's|^color_theme = .*|color_theme = "keqing"|' \
               -e 's|^theme_background = .*|theme_background = false|' "$conf"
    fi
    echo "btop: theme written (restart btop to apply)"
}

apply_vesktop() {
    local file="$HOME/.config/vesktop/settings/quickCss.css"
    write_file "$file"
    render_tmpl "$TMPL_DIR/vesktop.css.tmpl" "$file"
    echo "vesktop: quickCss.css written"
}

apply_fastfetch() {
    render_tmpl "$TMPL_DIR/fastfetch.jsonc.tmpl" \
                "$HOME/.config/fastfetch/config.jsonc"
    echo "fastfetch: config written"
}

apply_starship() {
    render_tmpl "$TMPL_DIR/starship.toml.tmpl" \
                "$HOME/.config/starship.toml"
    echo "starship: config written"
}

apply_zsh() {
    local file="$HOME/.config/keqing-shell/colors.zsh"
    write_file "$file"
    printf "KEQING_ACCENT_ANSI=\$'\\e[38;2;%sm'\n" "$ACCENT_RGB" > "$file"
    echo "zsh: colors.zsh written"
}

apply_btop
apply_cava
apply_fastfetch
apply_kitty
apply_starship
apply_vesktop
apply_zsh
hyprctl reload
