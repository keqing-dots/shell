#!/usr/bin/env bash

COLORS_JSON="$HOME/.config/keqing-shell/colors.json"
TMPL_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../templates"

# color helpers
hex_to_rgb() { local h="${1#'#'}"; printf "%d;%d;%d" $((16#${h:0:2})) $((16#${h:2:2})) $((16#${h:4:2})); }
lerp_hex()   {
    local c1="${1#'#'}" c2="${2#'#'}" i="$3"
    printf '#%02x%02x%02x' \
        $(( 16#${c1:0:2} + (16#${c2:0:2} - 16#${c1:0:2}) * i / 7 )) \
        $(( 16#${c1:2:2} + (16#${c2:2:2} - 16#${c1:2:2}) * i / 7 )) \
        $(( 16#${c1:4:2} + (16#${c2:4:2} - 16#${c1:4:2}) * i / 7 ))
}

# palette — single jq call for all 16 values
mapfile -t _c < <(jq -r '.current | [
    .base           // "#0A0614",
    .surface        // "#120B23",
    .surfaceAlt     // "#1D113B",
    .overlay        // "#26164B",
    .overlayAlt     // "#2F1C5F",
    .fieldBg        // "#170D30",
    .accent         // "#9B57F4",
    .accentAlt      // "#DBAA24",
    .accentDim      // "#693DC2",
    .accentContainer    // "#3C1877",
    .accentAltContainer // "#2A1957",
    .lavender       // "#806FBE",
    .lavenderLight  // "#CE8AFF",
    .rose           // "#C0547F",
    .text           // "#F0ECF9",
    .textMuted      // "#AB9DC8"
] | .[]' "$COLORS_JSON" 2>/dev/null)

export BASE="${_c[0]:-#0A0614}"
export SURFACE="${_c[1]:-#120B23}"
export SURFACE_ALT="${_c[2]:-#1D113B}"
export OVERLAY="${_c[3]:-#26164B}"
export OVERLAY_ALT="${_c[4]:-#2F1C5F}"
export FIELD_BG="${_c[5]:-#170D30}"
export ACCENT="${_c[6]:-#9B57F4}"
export ACCENT_ALT="${_c[7]:-#DBAA24}"
export ACCENT_DIM="${_c[8]:-#693DC2}"
export ACCENT_CONTAINER="${_c[9]:-#3C1877}"
export ACCENT_ALT_CONTAINER="${_c[10]:-#2A1957}"
export LAVENDER="${_c[11]:-#806FBE}"
export LAVENDER_LIGHT="${_c[12]:-#CE8AFF}"
export ROSE="${_c[13]:-#C0547F}"
export TEXT="${_c[14]:-#F0ECF9}"
export TEXT_MUTED="${_c[15]:-#AB9DC8}"

# derived
export ACCENT_RGB=$(hex_to_rgb "$ACCENT")
export LAVENDER_LIGHT_RGB=$(hex_to_rgb "$LAVENDER_LIGHT")
export ACCENT_ALT_RGB=$(hex_to_rgb "$ACCENT_ALT")
for i in 0 1 2 3 4 5 6 7; do
    export "GRADIENT_$((i+1))=$(lerp_hex "$ACCENT" "$LAVENDER" "$i")"
done

ENVSUBST_VARS='
    $BASE
    $SURFACE
    $SURFACE_ALT
    $OVERLAY
    $OVERLAY_ALT
    $FIELD_BG
    $ACCENT
    $ACCENT_ALT
    $ACCENT_DIM
    $ACCENT_CONTAINER
    $ACCENT_ALT_CONTAINER
    $LAVENDER
    $LAVENDER_LIGHT
    $ROSE
    $TEXT
    $TEXT_MUTED
    $ACCENT_RGB
    $LAVENDER_LIGHT_RGB
    $ACCENT_ALT_RGB
    $GRADIENT_1
    $GRADIENT_2
    $GRADIENT_3
    $GRADIENT_4
    $GRADIENT_5
    $GRADIENT_6
    $GRADIENT_7
    $GRADIENT_8
'

# file/template helpers
write_file() {
    local f="$1" d="${1%/*}"
    [[ -L "$d" ]] && rm -f "$d"
    mkdir -p "$d"
    [[ -L "$f" && ! -e "$f" ]] && rm -f "$f"
}

render_tmpl() {
    local tmpl="$1" out="$2"
    [[ -f "$tmpl" ]] || { echo "${tmpl##*/}: not found, skipping"; return; }
    envsubst "$ENVSUBST_VARS" < "$tmpl" > "$out"
}

apply() {
    local name="$1" tmpl="$2" out="$3" reload="${4:-}"
    write_file "$out"
    render_tmpl "$TMPL_DIR/$tmpl" "$out"
    if [[ -n "$reload" ]]; then
        $reload 2>/dev/null && echo "$name: reloaded" || echo "$name: config written"
    else
        echo "$name: config written"
    fi
}

C="$HOME/.config"

apply btop       btop.theme.tmpl            "$C/btop/themes/keqing.theme"
apply cava       cava.conf.tmpl             "$C/cava/config"                              "pkill -USR1 cava"
apply fastfetch  fastfetch.jsonc.tmpl       "$C/fastfetch/config.jsonc"
apply kitty      kitty.conf.tmpl            "$C/kitty/current-theme.conf"                 "pkill -USR1 kitty"
apply starship   starship.toml.tmpl         "$C/starship.toml"
apply vesktop    vesktop.css.tmpl           "$C/vesktop/settings/quickCss.css"
apply yazi       yazi-flavor.toml.tmpl      "$C/yazi/flavors/keqing.yazi/flavor.toml"
apply zsh        zsh-colors.zsh.tmpl        "$C/keqing-shell/colors.zsh"

hyprctl reload
