#!/usr/bin/env bash

set -euo pipefail
trap '_die "Script failed unexpectedly"' ERR

_die() {
    local message="$1"
    echo "ERROR: $message" >&2
    deps notify-send && notify-send "Keqing Error" "$message" 2>/dev/null || true
    exit 1
}
_help() {
cat <<'EOF'
    Keqing Shell Manager
    Usage: keqing-shell <command> [args]
           keqing-shell           Start shell (daemonized), locking on first start

    Setup:
        build               Build and install the C++ plugins (requires sudo)
        link                Symlink src/ into /etc/xdg/quickshell/ and script into /usr/local/bin/
        unlink              Remove both symlinks

    Shell operations:
        debug               Run keqing-shell in debug mode
        kill                Kill keqing-shell
        restart [debug] [rebuild] Kill and relaunch keqing-shell (debug: show output, rebuild: rebuild plugins first)
        reset               Kill, clear all cache/config, and relaunch
        track               Run quickshell under heaptrack
        help                Show this help message

    IPC:
        ipc                 Show all available IPC routes
        controlcenter       Toggle control center
        launcher            Toggle launcher
        lock                Toggle lock screen
        logout              Toggle logout screen
        matrix              Toggle matrix rain window
        overview            Toggle windows overview
        settings            Toggle settings panel
        visualizer          Toggle visualizer window
EOF
}
_here() { cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd; }
_qs()  { MALLOC_ARENA_MAX=2 quickshell -c keqing-shell "$@"; }
_ipc() { [[ -n "${1:-}" ]] && _qs ipc call "$1" toggle >/dev/null 2>&1 || _qs ipc show; }
_check_installed() {
    [[ -e /etc/xdg/quickshell/keqing-shell ]] \
        || _die "keqing-shell not installed (missing /etc/xdg/quickshell/keqing-shell)"
}
debug() { _qs; }
kill() { _qs kill >/dev/null 2>&1; }
force-kill() { killall quickshell; }
restart() {
    local _debug=0 _rebuild=0 _arg
    for _arg in "$@"; do
        case "$_arg" in
            debug) _debug=1 ;;
            rebuild) _rebuild=1 ;;
        esac
    done
    _qs kill >/dev/null 2>&1 || true
    sleep 1
    [[ $_rebuild -eq 1 ]] && build
    [[ $_debug -eq 1 ]] && _qs || _qs -d >/dev/null 2>&1
}
reset() {
    printf "This will delete all keqing-shell cache and config. Continue? [y/N] "
    read -r _reply
    [[ "${_reply,,}" == "y" ]] || { echo "Aborted."; return 0; }
    _qs kill >/dev/null 2>&1 || true
    sleep 1
    rm -rf "${XDG_CACHE_HOME:-$HOME/.cache}/quickshell" "${XDG_CACHE_HOME:-$HOME/.cache}/keqing-shell" "${XDG_CONFIG_HOME:-$HOME/.config}/keqing-shell"
    _qs -d >/dev/null 2>&1
}
build() {
    local _root; _root="$(cd "$(_here)/.." && pwd)"
    cmake -B "$_root/plugins/build" -DCMAKE_INSTALL_PREFIX=/usr "$_root/plugins"
    cmake --build "$_root/plugins/build"
    sudo cmake --install "$_root/plugins/build"
    rm -rf "$_root/plugins/build"
}
link() {
    local _src; _src="$(_here)/src"
    local _bin; _bin="$(_here)/keqing-shell"
    sudo mkdir -p /etc/xdg/quickshell
    sudo rm -f /etc/xdg/quickshell/keqing-shell
    sudo ln -s "$_src" /etc/xdg/quickshell/keqing-shell
    sudo ln -sf "$_bin" /usr/local/bin/keqing-shell
}
unlink() { sudo rm -f /etc/xdg/quickshell/keqing-shell /usr/local/bin/keqing-shell; }
track() {
    deps heaptrack || _die heaptrack not found 
    heaptrack quickshell -c keqing-shell
}
ipc()           { _ipc; }
controlcenter() { _ipc controlcenter; }
launcher()      { _ipc launcher; }
lock()          { _ipc lock; }
logout()        { _ipc logout; }
matrix()        { _ipc matrix; }
overview()      { _ipc overview; }
settings()      { _ipc settings; }
visualizer()    { _ipc visualizer; }

[[ $# -eq 0 ]] && {
    _check_installed
    _qs -d >/dev/null 2>&1
    _sentinel="/tmp/keqing-shell-started"
    [[ -f "$_sentinel" ]] || { touch "$_sentinel"; _ipc lock; }
    exit 0
}

_cmd=""
case "${1:-}" in
    help) _help; exit 0 ;;
    *) _cmd="$1"; shift ;;
esac

[[ -n "$_cmd" ]] || _die "expected: keqing-shell <command> [args]"
declare -f "$_cmd" >/dev/null 2>&1 || _die "command not found: $_cmd"
[[ "$_cmd" != _* ]] || _die "command not permitted: $_cmd"

case "$_cmd" in
    build|link|unlink) ;;
    *) _check_installed ;;
esac

"$_cmd" "$@"
